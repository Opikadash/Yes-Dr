{
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "installCommand": "cd web && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hoping-promised-blvd-paintings.trycloudflare.com/api/:path*"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://hoping-promised-blvd-paintings.trycloudflare.com/v1/:path*"
    }
  ]
}
